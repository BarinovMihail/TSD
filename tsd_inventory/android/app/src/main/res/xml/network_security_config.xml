<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Эмулятор: 10.0.2.2 → localhost хоста -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Реальный сервер 1С в сети ТСД (Wi-Fi OAIS5G) -->
        <domain includeSubdomains="false">192.168.1.51</domain>
        <!-- Локальная сеть -->
        <domain includeSubdomains="false">192.168.0.0</domain>
        <domain includeSubdomains="false">10.0.0.0</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
